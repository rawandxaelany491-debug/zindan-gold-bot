# تۆکنی بۆتی تلیگرام — لە @BotFather وەری بگرە
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# کلیلی Claude API — لە https://platform.claude.com وەری بگرە
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ئایدی تلیگرامی خۆت (خاوەنی بۆت) — بە فەرمانی /id لە بۆتەکە وەری بگرە
# یان لە @userinfobot لە تلیگرام
OWNER_TELEGRAM_ID=your_telegram_user_id_here

# (ئارەزوومەندانە) ناوی مۆدێلی Claude
# claude-haiku-4-5-20251001 = هەرزانترین و خێراترین (باشترین بۆ بودجەی بچووک)
# claude-sonnet-5 = کوالیتی بەرزتر، نرخی زیاتر
CLAUDE_MODEL=claude-haiku-4-5-20251001

# (ئارەزوومەندانە) زۆرترین درێژی وەڵام
CLAUDE_MAX_TOKENS=1500

# (ئارەزوومەندانە) بۆ ئاگادارکردنەوەی ڕۆژانە
TIMEZONE=Asia/Baghdad
DAILY_REMINDER_HOUR=9
DAILY_REMINDER_MINUTE=0

# (ئارەزوومەندانە) زۆرترین ژمارەی وێنەی شیکارکراو بۆ هەر بەکارهێنەرێک لە ڕۆژێکدا (خاوەن بێدەربازە)
DAILY_PHOTO_LIMIT=10

# (ئارەزوومەندانە) ڕاپۆرتی هەفتانە — ڕۆژ (٠=دووشەممە ... ٦=یەکشەممە)
WEEKLY_REPORT_DAY=6
WEEKLY_REPORT_HOUR=18
WEEKLY_REPORT_MINUTE=0